# Telegram Bot
# Obligatorio: Token del bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Obligatorio: Tu ID de usuario de Telegram (el bot solo respondera a ti)
# Para obtenerlo: envia /start a @userinfobot en Telegram
TELEGRAM_USER_ID=your_telegram_user_id_here


# Base de datos
# SQLite local - no requiere configuracion adicional
DATABASE_URL=sqlite:///./career_pilot.db


# Google OAuth
# El archivo credentials.json debe estar en la carpeta credentials/
GOOGLE_CREDENTIALS_FILE=credentials/credentials.json
GOOGLE_WORKSPACE_CLI_CREDENTIALS_FILE=./credentials/token.json


# Tu calendario de Google (normalmente tu email)
GOOGLE_CALENDAR_ID=your_email@gmail.com


# Scopes de Google (separados por coma)
GOOGLE_SCOPES=gmail.readonly,gmail.send,gmail.modify,calendar.readonly,calendar


# Configuracion General
TIMEZONE=Europe/Madrid
LOG_LEVEL=INFO
ENVIRONMENT=development


# Groq API (LLM principal - Llama 3.3 70B)
# Obtén tu API key gratis en https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here


# OpenRouter (fallback si se supera el límite de Groq)
# Obtén tu API key en https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free


# Nombre del usuario (para personalizar el mentor)
USER_NAME=Alberto


# Agent Settings
ALLOWED_TELEGRAM_IDS=your_telegram_user_id_here
MAX_AGENT_ITERATIONS=10


# APIs de Empleo

# JSearch via RapidAPI (https://rapidapi.com/jsearch/api/jsearch)
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna Job Search API (registro gratuito en https://developer.adzuna.com/signup)
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here


# Base de datos SQLite
DB_PATH=./data/memory.db